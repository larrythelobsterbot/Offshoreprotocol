# Server
PORT=3000
# Loopback by default. For public deploys behind a reverse proxy, set HOST=0.0.0.0
# AND set OPERATOR_API_TOKEN below (mutating endpoints will reject otherwise).
HOST=127.0.0.1

# Operator API token. Required when HOST is non-loopback and PUBLIC_MODE=false.
# Generate with: openssl rand -hex 32
# Required as `Authorization: Bearer <token>` for POST/DELETE /api/op-result.
OPERATOR_API_TOKEN=

# Comma-separated CORS allow list (added to defaults: localhost:3000, localhost:3456, DASHBOARD_URL).
# CORS_ORIGINS=https://my.custom.domain

# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Coinglass API (https://www.coinglass.com/pricing)
COINGLASS_API_KEY=

# Polymarket ETH 5M binary option token ID
# Find at: https://polymarket.com/crypto/5M — inspect the contract's token_id
POLYMARKET_TOKEN_ID=

# Telegram alerts (optional)
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert thresholds
ALERT_DANGER_HIGH=60
ALERT_DANGER_LOW=25
ALERT_COOLDOWN_MINUTES=15

# Data retention (days)
DATA_RETENTION_DAYS=30

# Student-t distribution degrees of freedom (lower = fatter tails, default: 4)
STUDENT_T_DF=4
