# Server
PORT=3000
HOST=0.0.0.0

# Coinglass API (https://www.coinglass.com/pricing)
COINGLASS_API_KEY=

# Polymarket ETH 5M binary option token ID
# Find at: https://polymarket.com/crypto/5M — inspect the contract's token_id
POLYMARKET_TOKEN_ID=

# Telegram alerts (optional)
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert thresholds
ALERT_DANGER_HIGH=60
ALERT_DANGER_LOW=25
ALERT_COOLDOWN_MINUTES=15

# Data retention (days)
DATA_RETENTION_DAYS=30

# Operation thresholds (max drop % that triggers failure)
EXTORTION_THRESHOLD=0.17
ARMS_THRESHOLD=0.71
DRUG_THRESHOLD=2.0

# Operation time windows (minutes)
EXTORTION_WINDOW_MIN=5
ARMS_WINDOW_MIN=30
DRUG_WINDOW_MIN=90

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Student-t distribution degrees of freedom (lower = fatter tails)
STUDENT_T_DF=4
